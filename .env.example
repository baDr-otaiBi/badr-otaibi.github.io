# Server
PORT=3000
NODE_ENV=production

# Moyasar Payment Gateway (https://moyasar.com)
MOYASAR_API_KEY=sk_test_xxxxxxxxxxxx
MOYASAR_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# JWT Secret (generate a random string)
JWT_SECRET=change_this_to_random_secret_key

# Site URL (used for callbacks)
SITE_URL=https://yourdomain.com

# WhatsApp number (with country code, no +)
WHATSAPP_NUMBER=966XXXXXXXXX
