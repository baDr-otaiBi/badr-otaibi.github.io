# Server
PORT=3000
NODE_ENV=production

# Moyasar Payment Gateway (https://moyasar.com)
MOYASAR_API_KEY=sk_test_xxxxxxxxxxxx
MOYASAR_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Admin credentials (USE STRONG PASSWORD - minimum 12 characters)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# JWT Secret (USE RANDOM STRING - minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET

# Site URL (used for CORS and callbacks)
SITE_URL=https://yourdomain.com

# WhatsApp number (with country code, no +)
WHATSAPP_NUMBER=966XXXXXXXXX
